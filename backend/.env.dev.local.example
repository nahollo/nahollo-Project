# Copy this file to .env.dev.local for local development.
# This file is safe to commit because it only contains placeholders.

APP_ENV=dev
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/<database>?sslmode=require
SPRING_DATASOURCE_USERNAME=<username>
SPRING_DATASOURCE_PASSWORD=<password>
DB_POOL_SIZE=10
